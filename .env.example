# Caddy (HTTPS): hosts para o certificado `tls internal` — tem de incluir tudo o que usas no browser (SNI).
# Sem o teu domínio/IP aqui: ERR_SSL_PROTOCOL_ERROR ao abrir https://domínio:9443
# (a :9443 é mapeada no host; o Caddy vê HTTPS na 443 dentro do contentor.)
# Exemplo remoto (ajusta IP e domínio):
# CADDY_SITE_ADDRESSES=localhost, 127.0.0.1, [::1], 178.105.37.126, corecraft-welton.duckdns.org
# CADDY_DEFAULT_SNI=corecraft-welton.duckdns.org
CADDY_SITE_ADDRESSES=localhost, 127.0.0.1, [::1]
CADDY_DEFAULT_SNI=localhost

BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASSWORD=bitcoinrpcdevpassword
BITCOIN_HOST=bitcoind
BITCOIN_RPC_PORT=8332
BITCOIN_NETWORK=main
# Signet (volume bitcoin-data novo ou vazio): BITCOIN_RPC_PORT=38332, BITCOIN_NETWORK=signet
# e bitcoin.conf com signet=1 + [signet] (ver histórico git).
# Disco: prune=15000 ~15 GiB de blocos; reserve ~25–30 GiB EBS no total.
# Porta única do PUB ZMQ (bitcoin.conf: todos os zmqpub* no mesmo tcp://0.0.0.0:PORT).
BITCOIN_ZMQ_PORT=28332
# Opcional: CSV de tópicos SUB (default no settings inclui hashblock,hashtx,rawblock,rawtx,sequence).
# BITCOIN_ZMQ_TOPICS=hashblock,hashtx

# Portas no host (stack em `stack/docker-compose.yml`). Omite para usar os defaults 8200, 5177, 9080, 9443.
# STACK_BACKEND_HOST_PORT=8200
# STACK_FRONTEND_HOST_PORT=5177
# STACK_HTTP_HOST_PORT=9080
# STACK_HTTPS_HOST_PORT=9443
