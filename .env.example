# Opcional: hosts HTTPS do Caddy (tls internal). Para abrir por https://IP_PUBLICO na EC2,
# acrescente o IPv4 à lista, ex.:
# CADDY_SITE_ADDRESSES=localhost, 127.0.0.1, [::1], 3.14.159.26
CADDY_SITE_ADDRESSES=localhost, 127.0.0.1, [::1]

BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASSWORD=bitcoinrpcdevpassword
BITCOIN_HOST=bitcoind
BITCOIN_RPC_PORT=8332
BITCOIN_NETWORK=main
# Signet (volume bitcoin-data novo ou vazio): BITCOIN_RPC_PORT=38332, BITCOIN_NETWORK=signet
# e bitcoin.conf com signet=1 + [signet] (ver histórico git).
# Disco: prune=15000 ~15 GiB de blocos; reserve ~25–30 GiB EBS no total.
# Porta única do PUB ZMQ (bitcoin.conf: todos os zmqpub* no mesmo tcp://0.0.0.0:PORT).
BITCOIN_ZMQ_PORT=28332
# Opcional: CSV de tópicos SUB (default no settings inclui hashblock,hashtx,rawblock,rawtx,sequence).
# BITCOIN_ZMQ_TOPICS=hashblock,hashtx
