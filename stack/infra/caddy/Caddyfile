# :80 e :443 escutam em todas as interfaces do container (0.0.0.0).
# Assim o mapeamento Docker "80:80" / "443:443" recebe tráfego externo (IP público da EC2)
# e também continua funcionando com https://localhost no seu notebook.
#
# Com `tls internal`, os nomes do site têm de bater com o host/SNI do browser (incluindo
# o IPv4 público se aceder por https://IP). A lista vem de CADDY_SITE_ADDRESSES (.env),
# definida no docker-compose (default: localhost e loopbacks).
#
# default_sni: muitos curl (LibreSSL / versões antigas) NÃO enviam SNI ao usar URL só
# com IPv4; o Caddy precisa de um fallback ou responde com TLS "internal error". Na EC2
# com https://IP público, defina CADDY_DEFAULT_SNI igual a esse IP (ver .env.example).

{
	default_sni {$CADDY_DEFAULT_SNI:localhost}
}

:80 {
	redir https://{host}{uri}
}

{$CADDY_SITE_ADDRESSES} {
	tls internal

	# Todas as chamadas da API passam pelo backend.
	handle_path /api/* {
		reverse_proxy backend:8000
	}

	# WebSocket de eventos em tempo real.
	handle /ws/* {
		reverse_proxy backend:8000
	}

	# Frontend React (Vite dev server no container frontend).
	handle {
		reverse_proxy frontend:5173
	}
}
