# Caddy “edge” na 443 — proxy para o stack-caddy no host (9443).
#
# ERROS COMUNS → SSL_ERROR_INTERNAL_ERROR_ALERT
# 1) Falta tls_server_name no reverse_proxy (SNI para 172.17.0.1 sem nome → handshake falha).
# 2) zconfcore também está em {$CADDY_SITE_ADDRESSES} do CORECRAFT → dois blocos para o mesmo
#    host (tls internal vs Let's Encrypt). Remove zconfcore do .env do CORECRAFT.
# 3) Let's Encrypt falhou (80 bloqueado, DNS errado). Ver: docker logs corecraft-caddy | grep -i acme
#    Teste: troca temporariamente por `tls internal` neste bloco; se abrir (com aviso), o problema é LE.
#
# No BITCOIND-LAB (.env com CADDY_SITE_ADDRESSES + zconfcore): stack/docker-compose + stack-caddy.

zconfcore.duckdns.org {
	# Let's Encrypt (browser sem aviso). Email válido.
	tls seu-email@exemplo.com

	reverse_proxy https://172.17.0.1:9443 {
		transport http {
			tls
			tls_insecure_skip_verify
			# OBRIGATÓRIO: mesmo hostname que no certificado tls internal do stack-caddy.
			tls_server_name zconfcore.duckdns.org
		}
		header_up Host {http.request.host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {remote_host}
		header_up X-Real-IP {remote_host}
	}
}
