# ============================================================================
# Stack (MariaDB, API, frontend, Caddy) — `cd stack && docker compose ...`
# Copiar: cp stack/.env.example stack/.env
#
# Compose: `../.env` (opcional) + este ficheiro — variáveis repetidas ganham em stack/.env.
# 502 em https://…:9443 costuma ser backend em baixo; ver `docker compose logs backend`.
# ============================================================================

# --- Bitcoin Core (lido pelo backend; deve coincidir com ../.env na raiz para RPC user/pass) ---
# Compose com bitcoind no mesmo docker network (default):
BITCOIN_HOST=bitcoind
# Bitcoind só no host (localhost:38332 exposto): usa host.docker.internal no contentor backend (Linux/Mac).
# BITCOIN_HOST=host.docker.internal
# Backend a correr na máquina (uvicorn sem Docker) + bitcoind no host:
# BITCOIN_HOST=127.0.0.1
BITCOIN_RPC_PORT=38332
BITCOIN_NETWORK=signet
BITCOIN_ZMQ_PORT=28332
# Carteira única do operador (listada no bitcoind) — painel /adm/node/wallet
# BITCOIN_OPERATOR_WALLET=app
# Label do endereço reservado para taxa/depósito operacional (índice lógico 0 no painel).
# BITCOIN_FEE_ADDRESS_LABEL=fee-index-0
# ZMQ: só tx da carteira do operador (hashtx filtrado via gettransaction no backend).
# BITCOIN_ZMQ_FILTER_WALLET_TXS_ONLY=1
# BITCOIN_ZMQ_WALLET_FILTER_CACHE_TTL_SEC=20
# BITCOIN_ZMQ_WALLET_FILTER_MAX_CONCURRENCY=6
# BITCOIN_ZMQ_WALLET_FILTER_MAX_PENDING=300
# Tópicos publicados no bitcoind (bitcoin.conf). Referência; o que a consola retransmite é
# `BITCOIN_ZMQ_RELAY_TOPICS` (por defeito hashblock + hashtx).
# BITCOIN_ZMQ_TOPICS=hashblock,hashtx,rawblock,rawtx,sequence
# BITCOIN_ZMQ_RELAY_TOPICS=hashblock,hashtx

# --- Signet demo: depósito manual no endereço mostrado (getnewaddress por ordem). ZMQ → backend → mocks na BD.
# SIGNET_DEMO_PROGRESS_STEP_SEC=8.0
# (Legado, ignorado no fluxo actual: TRIGGER/DEPOSIT env para tx-gatilho interna.)
# SIGNET_DEMO_TRIGGER_ADDRESS=
# SIGNET_DEMO_DEPOSIT_ADDRESS=

# --- Caddy (HTTPS / SNI) ---
CADDY_SITE_ADDRESSES=localhost, 127.0.0.1, [::1]
CADDY_DEFAULT_SNI=localhost

# --- MariaDB ---
MARIADB_DATABASE=stack
MARIADB_USER=stack
MARIADB_PASSWORD=stackdevpassword
MARIADB_ROOT_PASSWORD=stackrootdevpassword

# --- Backend: sessão admin (cookie assinado). openssl rand -hex 32 ---
SECRET_KEY=change-me-use-openssl-rand-hex-32
# COOKIE_SECURE=1

# Bootstrap do primeiro utilizador admin (tabela vazia).
ADM_BOOTSTRAP_USERNAME=admin
ADM_BOOTSTRAP_PASSWORD=troca-me-forte
# Contato exibido no cliente-homologacao quando uma ordem falha.
ADMIN_CONTACT_EMAIL=admin@site.com

# --- Bitrefill («Compras»): API REST v2 ---
# Chave Personal (Account → Developers). Não commitar valores reais — apenas em stack/.env local.
# BITREFILL_ENABLED=1
# BITREFILL_API_KEY=
# BITREFILL_BASE_URL=https://api-bitrefill.com/v2
# BITREFILL_TIMEOUT_SEC=25
# BITREFILL_SPREAD_SAT=1000
# Smoke pytest contra API Bitrefill real (ver tests/bitrefill/test_live_integration.py):
# BITREFILL_RUN_LIVE=1
# BITREFILL_TEST_INVOICE_ID=

# --- Dev: Vite (`cd frontend && npm run dev`) — proxy para API local (ler env em stack/.env, envDir=stack/) ---
# Por defeito no vite.config: http://127.0.0.1:8200 — descomenta só para outro host/porta:
# VITE_DEV_API_PROXY=http://127.0.0.1:8200
# VITE_DEV_WS_PROXY=ws://127.0.0.1:8200

# --- Portas no host (opcional) ---
# STACK_MARIADB_HOST_PORT=3306
# STACK_BACKEND_HOST_PORT=8200
# STACK_FRONTEND_HOST_PORT=5177
# STACK_HTTP_HOST_PORT=9080
# HTTPS público (browser / fetch / cookies); Caddy usa isto no redirect HTTP→HTTPS.
# STACK_HTTPS_HOST_PORT=9443
