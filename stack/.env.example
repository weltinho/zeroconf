# ============================================================================
# Stack (MariaDB, API, frontend, Caddy) — `cd stack && docker compose ...`
# Copiar: cp stack/.env.example stack/.env
#
# O backend também carrega `../.env` (raiz) para BITCOIN_RPC_* alinhados com o bitcoind.
# ============================================================================

# --- Bitcoin Core (lido pelo backend; deve coincidir com ../.env na raiz) ---
BITCOIN_HOST=bitcoind
BITCOIN_RPC_PORT=38332
BITCOIN_NETWORK=signet
BITCOIN_ZMQ_PORT=28332
# Carteira única do operador (listada no bitcoind) — painel /adm/node/wallet
# BITCOIN_OPERATOR_WALLET=app
# Label do endereço reservado para taxa/depósito operacional (índice lógico 0 no painel).
# BITCOIN_FEE_ADDRESS_LABEL=fee-index-0
# ZMQ: só tx da carteira do operador (hashtx filtrado via gettransaction no backend).
# BITCOIN_ZMQ_FILTER_WALLET_TXS_ONLY=1
# BITCOIN_ZMQ_WALLET_FILTER_CACHE_TTL_SEC=20
# BITCOIN_ZMQ_WALLET_FILTER_MAX_CONCURRENCY=6
# BITCOIN_ZMQ_WALLET_FILTER_MAX_PENDING=300
# Tópicos publicados no bitcoind (bitcoin.conf). Referência; o que a consola retransmite é
# `BITCOIN_ZMQ_RELAY_TOPICS` (por defeito hashblock + hashtx).
# BITCOIN_ZMQ_TOPICS=hashblock,hashtx,rawblock,rawtx,sequence
# BITCOIN_ZMQ_RELAY_TOPICS=hashblock,hashtx

# --- Caddy (HTTPS / SNI) ---
CADDY_SITE_ADDRESSES=localhost, 127.0.0.1, [::1]
CADDY_DEFAULT_SNI=localhost

# --- MariaDB ---
MARIADB_DATABASE=stack
MARIADB_USER=stack
MARIADB_PASSWORD=stackdevpassword
MARIADB_ROOT_PASSWORD=stackrootdevpassword

# --- Backend: sessão admin (cookie assinado). openssl rand -hex 32 ---
SECRET_KEY=change-me-use-openssl-rand-hex-32
# COOKIE_SECURE=1

# Bootstrap do primeiro utilizador admin (tabela vazia).
ADM_BOOTSTRAP_USERNAME=admin
ADM_BOOTSTRAP_PASSWORD=troca-me-forte

# --- Portas no host (opcional) ---
# STACK_MARIADB_HOST_PORT=3306
# STACK_BACKEND_HOST_PORT=8200
# STACK_FRONTEND_HOST_PORT=5177
# STACK_HTTP_HOST_PORT=9080
# HTTPS público (browser / fetch / cookies); Caddy usa isto no redirect HTTP→HTTPS.
# STACK_HTTPS_HOST_PORT=9443
