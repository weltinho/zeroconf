# Valores por omissão do Caddy (carregados antes do `../.env`, que sobrescreve).
# Assim o contentor recebe sempre nomes TLS válidos mesmo sem editar o `.env` na raiz.
CADDY_SITE_ADDRESSES=localhost, 127.0.0.1, [::1]
CADDY_DEFAULT_SNI=localhost
# Porta HTTPS no host (mapeada para :443 no container); usada no redirecionamento :80→HTTPS.
STACK_HTTPS_HOST_PORT=9443
